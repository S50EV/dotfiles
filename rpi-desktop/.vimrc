set nocompatible
syntax on
set rnu
colorscheme retrobox
set cursorline

set expandtab
set tabstop=2
set shiftwidth=2
set autoindent
set smartindent

set ignorecase
set smartcase
set incsearch
set hlsearch

set termguicolors
set splitright
set splitbelow
set scrolloff=8

let mapleader = " "
nnoremap <leader>w :w<cr>
nnoremap <esc> :noh<return><esc>
